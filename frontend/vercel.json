{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/urbanpulse/browser" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://urbanpulse-api.up.railway.app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_VERSION": "20"
  }
}
