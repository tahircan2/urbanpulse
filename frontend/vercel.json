{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/urbanpulse/browser" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://urbanpulse-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_VERSION": "20"
  }
}
